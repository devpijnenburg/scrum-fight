POSTGRES_DB=planningpoker
POSTGRES_USER=poker
POSTGRES_PASSWORD=changeme

JWT_SECRET=your_very_secret_key_here

# OAuth — leave empty to disable the provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL (no trailing slash)
BASE_URL=http://localhost

# Host port for the frontend container (default 80)
PORT=80

# Polar.sh payments — leave empty to disable
# Access token from https://polar.sh/settings
POLAR_ACCESS_TOKEN=
# Webhook secret from the webhook settings in your Polar.sh project
POLAR_WEBHOOK_SECRET=
# Product IDs for each personal plan (copy from the Polar.sh product page)
POLAR_PRO_PRODUCT_ID=
POLAR_PREMIUM_PRODUCT_ID=
