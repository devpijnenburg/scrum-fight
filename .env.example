POSTGRES_DB=planningpoker
POSTGRES_USER=poker
POSTGRES_PASSWORD=changeme

JWT_SECRET=your_very_secret_key_here

# OAuth — leave empty to disable the provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL (no trailing slash)
BASE_URL=http://localhost

# Host port for the frontend container (default 80)
PORT=80

# Creem.io payments — leave empty to disable
# API key from https://creem.io/dashboard/developers
CREEM_API_KEY=
# Webhook secret from the webhook settings in your Creem.io project
CREEM_WEBHOOK_SECRET=
# Product IDs per plan and billing period (copy from the Creem.io product pages)
CREEM_PRO_MONTHLY_PRODUCT_ID=
CREEM_PRO_YEARLY_PRODUCT_ID=
CREEM_PREMIUM_MONTHLY_PRODUCT_ID=
CREEM_PREMIUM_YEARLY_PRODUCT_ID=
