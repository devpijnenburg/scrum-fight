POSTGRES_DB=planningpoker
POSTGRES_USER=poker
POSTGRES_PASSWORD=changeme

JWT_SECRET=your_very_secret_key_here

# OAuth — leave empty to disable the provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL (no trailing slash)
BASE_URL=http://localhost

# Host port for the frontend container (default 80)
PORT=80

# ── E-mail (SMTP) ──────────────────────────────────────────────────────────────
#
# OPTIE 1 — Lokale ontwikkeling: Mailpit (vangt mails op, verstuurt ze NIET)
# Start met: docker compose up  (Mailpit staat in docker-compose.yml)
# Bekijk mails op: http://localhost:8025
#
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=Scrum Fight <noreply@scrumfight.nl>
# SMTP_STARTTLS=false
# SMTP_SSL_TLS=false
#
# OPTIE 2 — Productie via freedom.nl
# Gebruik een e-mailaccount op jouw domein (bijv. noreply@pijnenburg.pro).
# SMTP-instellingen staan in je freedom.nl-configuratiepaneel onder E-mail → Instellingen.
#
SMTP_HOST=smtp.freedom.nl
SMTP_PORT=587
SMTP_USER=noreply@pijnenburg.pro
SMTP_PASSWORD=changeme
SMTP_FROM=Scrum Fight <noreply@pijnenburg.pro>
SMTP_STARTTLS=true
SMTP_SSL_TLS=false
#
# Wil je poort 465 (SSL) gebruiken, zet dan:
# SMTP_PORT=465
# SMTP_STARTTLS=false
# SMTP_SSL_TLS=true
# ──────────────────────────────────────────────────────────────────────────────

# E-mailadres voor interne notificaties
ROB_EMAIL=scrumfight@pijnenburg.pro
